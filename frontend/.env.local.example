# Copy this to .env.local and fill in contract IDs after running scripts/deploy.sh

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Filled automatically by deploy.sh:
NEXT_PUBLIC_POOL_CONTRACT_ID=
NEXT_PUBLIC_LP_TOKEN_CONTRACT_ID=
NEXT_PUBLIC_XLM_CONTRACT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=

# A funded testnet account public key for read-only simulations:
NEXT_PUBLIC_SIMULATOR_KEY=
